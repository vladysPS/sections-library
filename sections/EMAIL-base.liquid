

<!-- pango-EMAIL-base.liquid -->

<section class="p-{{ section.id }}">
 <div class="page-width">
    {% form 'customer' %}
    <div class="p-email-container">
        <input class="p-email-input" type="email" name="contact[email]" autocomplete="email" placeholder="{{ 'newsletter.label' | t }}" required/>
        
        <button type="submit" class="p-submit-button" name="commit" id="Subscribe" aria-label="{{ 'newsletter.button_label' | t }}">
            {% render 'icon-arrow' %}
        </button>
    </div>

    {%- if form.errors -%}
        <small class="newsletter-form__message form__message" id="ContactFooter-error">{% render 'icon-error' %}{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</small>
    {%- endif -%}
    {%- if form.posted_successfully? -%}
        <div class="newsletter-form__message newsletter-form__message--success form__message" id="ContactFooter-success" tabindex="-1" autofocus>{{ 'newsletter.success' | t }}</div>
    {%- endif -%}            

{% endform %}
 </div> 
</section>




