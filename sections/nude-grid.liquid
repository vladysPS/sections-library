<!-- nude-grid.liquid -->


<section class="p-{{ section.id }}">
 <div class="page-width">
  <div class="grid-wrapper">
    {% for product in collection.products %}

      <div class="product-card">
        <h4>{{ product.title }}</h4>
      </div>

      {% assign index_minus_four = forloop.index | minus: 4 %}
      {% assign remainder = index_minus_four | modulo: 8 %}
      {% if forloop.index == 4 or forloop.index > 4 and remainder == 0 %}
        <div class="image grid-image-span">
          <p>Ad/Image Break</p>
        </div>
      {% endif %}

    {% endfor %}
  </div>
 </div> 
</section>


{%  # CSS  %}
<style>
.grid-image-span{
  grid-column: span 2;
  grid-row:span 2;
}
.p-{{ section.id }}{
  /* MAIN STYLES */
  .page-width{
    padding: 1rem;
  }
  .product-card{
    background-color: pink;
    border: 2px solid orange;
    height: 100%;
  }
  .image{
    background-color: blue;
    border: 1px solid orangered;
    height:100%;
  }
  /* GRID AND QUERIES SETUP */
  .grid-wrapper{
    display: grid;
    gap: 1.3rem;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: 150px;
  }
  @media(min-width:700px){
    .image{
      display:none;
    }
    .grid-wrapper{
        grid-template-columns: repeat(3, 1fr);
    }
  }
  @media(min-width:900px){
    .image{
      display:block;
    }
    .grid-wrapper{
        grid-template-columns: repeat(4, 1fr);
    }
  }


}





</style>


