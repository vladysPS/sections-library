<!-- nude-grid.liquid -->


{% assign ad_counter = 0 %}

<section class="p-{{ section.id }}">
 <div class="page-width">
  <div class="grid-wrapper">
    {% for product in collection.products %}

      <div class="product-card">
        <h4>{{ product.title }}</h4>
      </div>

      {% assign index_minus_four = forloop.index | minus: 8 %}
      {% assign remainder = index_minus_four | modulo: 8 %}
      
      {% if forloop.index == 4 %}
        <div class="image grid-image-span-first">
          <p>Ad/Image Break</p>
        </div>
      {% endif %}

      {% if forloop.index == 8 %}
        <div class="image grid-image-span-regular">
          <p>Ad/Image Break</p>
        </div>
      {% endif %}

      {% if forloop.index > 8 and remainder == 0 %}
        {% comment %} 
          Increment our custom counter and check if it's even or odd 
        {% endcomment %}
        {% assign ad_counter = ad_counter | plus: 1 %}
        {% assign side_remainder = ad_counter | modulo: 2 %}
        
        <div class="image grid-image-span-regular {% if side_remainder == 1 %}grid-image-span-right{% else %}grid-image-span-left{% endif %}">
          <p>Ad/Image Break</p>
        </div>
      {% endif %}

    {% endfor %}
  </div>
 </div> 
</section>


{%  # CSS  %}
<style>

.grid-image-span-regular{
    grid-column: span 2;
    grid-row:span 2;
}
.grid-span-first-right{
  grid-column: 3 / 5;
  grid-row: 1 / 3;
}
.p-{{ section.id }}{
  /* MAIN STYLES */
  .page-width{
    padding: 1rem;
  }
  .product-card{
    background-color: pink;
    border: 2px solid orange;
    height: 100%;
  }
  .image{
    background-color: blue;
    border: 1px solid orangered;
    height:100%;
  }
  .grid-image-span-first{
    grid-column: span 2;
    grid-row:span 2;
  }
  /* GRID AND QUERIES SETUP */
  .grid-wrapper{
    display: grid;
    gap: 1.3rem;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: 200px;
  }
  @media(min-width:700px){
    .image{
      display:none;
    }
    .grid-wrapper{
        grid-template-columns: repeat(3, 1fr);
        grid-auto-rows: 270px;
    }
  }
  @media(min-width:900px){
    .image{
      display:block;
    }
    .grid-image-span-first{
        grid-column: 3 / 5;
        grid-row: 1 / 3;
    }
    .grid-image-span-left{
      grid-column: 1 / span 2;
      grid-row: span 2;
    }
    .grid-image-span-right{
      grid-column: 3 / span 2;
      grid-row: span 2;
    }
    .grid-wrapper{
        grid-template-columns: repeat(4, 1fr);
        grid-auto-rows: 340px;
        grid-auto-flow: dense;
    }
  }

}





</style>


