<section class="p-{{ section.id }}">
  <div class="fieldset-wrapper">
    <div class="date-selector">
      <label for="start">Test date:</label>
      <input
        type="date"
        id="start"
        name="trip-start"
        value="2026-04-04"
        min="2024-04-01"
        max="2100-12-31" />

    </div>
    <fieldset class="visual-selector-corte">
      <legend>Hora de corte:</legend>
      <div>
        <input class="corte-true" type="radio" id="true-corte" name="drone" value="true-corte" checked />
        <label for="true-corte">Antes </label>
      </div>

      <div>
        <input class="corte-false" type="radio" id="false-corte" name="drone" value="false-corte" />
        <label for="false-corte">Después</label>
      </div>
    </fieldset>

    <fieldset class="visual-selector-M50">
      <legend>Zona de entrega:</legend>
      <div>
        <input class="m50-true" type="radio" id="true-M50" name="m50" value="true-M50" checked />
        <label for="true-M50">Dentro de M50</label>
      </div>

      <div>
        <input class="m50-false" type="radio" id="false-M50" name="m50" value="false-M50" />
        <label for="false-M50">Fuera de M50</label>
      </div>
    </fieldset>

    <fieldset class="visual-cart">
      <legend> Cart con Producto +24h:</legend>
      <div>
        <input class="cart-true" type="radio" id="true-cart" name="cart" value="true-cart"  />
        <label for="true-cart">True</label>
      </div>

      <div>
        <input class="cart-false" type="radio" id="false-cart" name="cart" value="false-cart" checked />
        <label for="false-cart">False</label>
      </div>
    </fieldset>
  </div>
    <div class="calendar-container">
        <div class="container">
            <div class="cal">
                <div class="cal__header">
                    <button class="btn-action" data-calendar-toggle="previous" aria-label="Previous Month">
                        <svg height="24" viewBox="0 0 24 24" width="24"><path d="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z"></path></svg>
                    </button>
                    <div class="cal__header__label" data-calendar-label="month"></div>
                    <button class="btn-action" data-calendar-toggle="next" aria-label="Next Month">
                        <svg height="24" viewBox="0 0 24 24" width="24"><path d="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z"></path></svg>
                    </button>
                </div>
                <div class="cal__week">
                    <span>Lun</span><span>Mar</span><span>Mie</span><span>Jue</span><span>Vie</span><span>Sáb</span><span>Dom</span>
                </div>
                <div class="cal__body" data-calendar-area="month"></div>
            </div>

            <p class="demo-picked">
                <strong>Fecha seleccionada:</strong> <span data-calendar-label="picked">Por favor seleccione una fecha</span>
            </p>
            <p class="cal-error-message" id="cal-error" style="display:none; color: #d9534f; font-weight: bold; margin-top: 10px;"></p>
            <input type="hidden" name="attributes[Delivery Date]" id="calendar-date-input">
        </div>
    </div>
</section>

<style>
.p-{{ section.id }} {
  --primary-color: #0A9297;
  --bg-light: #E7E9ED;
  --text-main: #333;
  --cell-size: 40px; /* Fixed size for the day circles */
  .fieldset-wrapper{
    padding-inline: 50px;
    display: flex;
    flex-wrap: wrap;
    gap:40px;
  }
  .fieldset-wrapper > * {
    flex: 1;
  }
  .container {
    width: 96%;
    margin: 2rem auto;
    max-width: 450px;
    text-align: center;
  }

  .cal {
    width: 100%;
    background-color: #fff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    border: 1px solid var(--bg-light);
  }

  .cal__header {
    display: flex;
    padding: 1.2rem;
    align-items: center;
    justify-content: space-between;
  }

  .btn-action {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    display: flex;
    align-items: center;
    transition: opacity 0.2s;
  }
  
  .cal__header svg { fill: var(--primary-color); }
  .cal__header__label { font-weight: 800; font-size: 1.1rem; }

  .cal__week {
    display: flex;
    background-color: var(--bg-light);
  }

  .cal__week span {
    flex: 0 0 14.285%;
    font-size: 0.7rem;
    padding: 10px 0;
    text-transform: uppercase;
    font-weight: 700;
    color: #666;
  }

  .cal__body {
    display: flex;
    flex-wrap: wrap;
    padding: 10px 0;
    min-height: 280px; /* Prevents height bounce between 5 and 6 row months */
  }

  .cal__date {
    flex: 0 0 14.285%;
    height: 48px; /* Fixed height for the grid cell */
    display: flex;
    justify-content: center;
    align-items: center;
    box-sizing: border-box;
  }

  /* Inner Circle - This prevents the bounce because the border/bg is inside a fixed box */
  .cal__date span {
    width: var(--cell-size);
    height: var(--cell-size);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%; /* Circular look */
    transition: all 0.2s ease;
    border: 2px solid transparent; /* Placeholder to prevent shift */
    font-size: 0.9rem;
  }

  /* Today's style: Teal border, no fill */
  .cal__date--today span {
    border-color: var(--primary-color);
    color: var(--primary-color);
    font-weight: bold;
  }

  .cal__date--active { cursor: pointer; }

  .cal__date--active:hover span {
    background-color: #f0f0f0;
  }

  /* Selected state: Solid fill */
  .cal__date--selected span {
    background-color: var(--primary-color) !important;
    color: #fff !important;
    border-color: var(--primary-color) !important;
  }

  .cal__date--disabled {
    opacity: 0.25;
    cursor: not-allowed !important;
  }

  .demo-picked {
    margin-top: 1.5rem;
    font-size: 0.9rem;
    color: var(--text-main);
  }
  .cal-error-message {
  font-size: 0.85rem;
  min-height: 1.2rem; /* Keeps space so layout doesn't jump when it appears */
}
}
</style>

<script>
function isUserInMadridTimezone() {
  return Intl.DateTimeFormat().resolvedOptions().timeZone === "Europe/Madrid";
}

//SELECTORES
const cartPlusOneEle = document.querySelector('.visual-cart');
const cartPlusTrue = cartPlusOneEle.querySelector(".cart-true");
const cartPlusFalse = cartPlusOneEle.querySelector(".cart-false");

cartPlusTrue.addEventListener("change", () => {
  if (cartPlusTrue.checked) {
    vanillacalendar.cartPlusOne = true;
    vanillacalendar.render();
  }
});
cartPlusFalse.addEventListener("change", () => {
  if (cartPlusFalse.checked) {
    vanillacalendar.cartPlusOne = false;
    vanillacalendar.render();
  }
});

const dateInput = document.querySelector('.date-selector input[type="date"]');
dateInput.addEventListener("change", (e) => {
  const selecetedDateValue = e.target.value; 
  if (!selecetedDateValue) return;

  const newDate = new Date(selecetedDateValue);
  vanillacalendar.date = new Date(newDate.getFullYear(), newDate.getMonth(), 1);
  vanillacalendar.todaysDate = newDate;
  vanillacalendar.render();
})

const horaCorteElement = document.querySelector(".visual-selector-corte");
const radioCorteTrue = horaCorteElement.querySelector(".corte-true");
const radioCorteFalse = horaCorteElement.querySelector(".corte-false");

radioCorteTrue.addEventListener("change", () => {
  if (radioCorteTrue.checked) {
    vanillacalendar.horaCorte = true;
    vanillacalendar.render();
  }
});
radioCorteFalse.addEventListener("change", () => {
  if (radioCorteFalse.checked) {
    vanillacalendar.horaCorte = false;
    vanillacalendar.render();
  }
});

const m50Element = document.querySelector(".visual-selector-M50");
const radioM50True = m50Element.querySelector(".m50-true");
const radioM50False = m50Element.querySelector(".m50-false");

radioM50True.addEventListener("change", () => {
  if (radioM50True.checked) {
    vanillacalendar.dentroM50 = true;
    vanillacalendar.render();
  }
});
radioM50False.addEventListener("change", () => {
  if (radioM50False.checked) {
    vanillacalendar.dentroM50 = false;
    vanillacalendar.render();
  }
});

// function getMadridDate() {
//   return new Date(
//     new Intl.DateTimeFormat("en-CA", {
//       timeZone: "Europe/Madrid",
//       year: "numeric",
//       month: "2-digit",
//       day: "2-digit"
//     }).format(new Date())
//   );
// }

// const madridDate = getMadridDate();
// console.log("madrid date", madridDate);
// console.log("auto date", new Date() );

// LÓGICA DE CALENDARIO
let horaCorte = true; 
let dentroM50 = true; 
let cartPlusOne = false;

// LÓGICA DÍAS NO DISPONIBLES
function normalizeDate(date) {
  return new Date(date).setHours(0, 0, 0, 0);
}

let diasNoDisponibles = [
  '2026-04-20',
  '2026-04-21',
  '2026-04-22',
  '2026-04-23',
  '2026-04-24',
  '2026-04-25',
  '2026-04-26',
].map(d => normalizeDate(d));

function isDateUnavailable(date) {
  const normalized = normalizeDate(date);
  return diasNoDisponibles.includes(normalized);
}

// LÓGICA PARA FUERA M50
const reglasFueraM50 = {
  1: { // Lunes
    before: [4], // Jueves
    after: [5]   // Viernes
  },
  2: { // Martes
    before: [5], // Viernes
    after: [2]   // Martes
  },
  3: { // Miércoles
    before: [2], // Martes
    after: [3]   // Miércoles
  },
  4: { // Jueves
    before: [3], // Miércoles
    after: [4]   // Jueves
  },
  5: { // Viernes
    before: [4], // Jueves
    after: [5]   // Viernes
  },
  6: { // Sábado
    before: [4], // Jueves
    after: [5]   // Viernes
  },
  0: { // Domingo
    before: [4], // Jueves
    after: [5]   // Viernes
  }
};

function getAllowedWeekdays(today, horaCorte) {
  const day = new Date(today).getDay();
  const tipo = horaCorte ? "before" : "after";

  return reglasFueraM50[day][tipo];
}

function getNextWeekday(baseDate, targetDay) {
  const date = new Date(baseDate);
  const currentDay = date.getDay();

  let diff = targetDay - currentDay;
  if (diff <= 0) diff += 7;

  date.setDate(date.getDate() + diff);
  return new Date(date).setHours(0,0,0,0);
}

const vanillacalendar = {
  monthArea: document.querySelector('[data-calendar-area="month"]'),
  nextBtn: document.querySelector('[data-calendar-toggle="next"]'),
  prevBtn: document.querySelector('[data-calendar-toggle="previous"]'),
  label: document.querySelector('[data-calendar-label="month"]'),
  pickedLabel: document.querySelector('[data-calendar-label="picked"]'),
  hiddenInput: document.getElementById('calendar-date-input'),
  
  date: new Date(),
  todaysDate: new Date(),

  // --- LOGIC SETTINGS ---
  horaCorte: horaCorte,   
  dentroM50: dentroM50,  
  cartPlusOne: cartPlusOne, 

  init: function () {
    this.date.setDate(1);
    this.render();
    this.createListeners();
  },

  createListeners: function () {
    this.nextBtn.addEventListener('click', (e) => {
      e.preventDefault();
      this.date.setMonth(this.date.getMonth() + 1);
      this.render();
    });
    this.prevBtn.addEventListener('click', (e) => {
      e.preventDefault();
      this.date.setMonth(this.date.getMonth() - 1);
      this.render();
    });
  },

  render: function () {
    this.monthArea.innerHTML = '';
    const month = this.date.getMonth();
    const year = this.date.getFullYear();
    const monthName = new Intl.DateTimeFormat('es-ES', { month: 'long' }).format(this.date);
    this.label.innerHTML = `${monthName} ${year}`;

    let firstDay = new Date(year, month, 1).getDay(); 
    let offset = firstDay === 0 ? 6 : firstDay - 1; 

    for (let i = 0; i < offset; i++) {
      const emptyDiv = document.createElement('div');
      emptyDiv.className = 'cal__date';
      this.monthArea.appendChild(emptyDiv);
    }

    const daysInMonth = new Date(year, month + 1, 0).getDate();
    for (let i = 1; i < daysInMonth + 1; i++) {
      const actualDate = new Date(year, month, i);
      this.createDay(i, actualDate);
    }
  },

  createDay: function (num, actualDate) {
    const dayEl = document.createElement('div');
    const errorEl = document.getElementById('cal-error');
    dayEl.className = 'cal__date';
    dayEl.innerHTML = `<span>${num}</span>`;

    const checkDate = new Date(actualDate).setHours(0,0,0,0);
    const today = new Date(this.todaysDate).setHours(0,0,0,0);
    const dayOfWeek = actualDate.getDay(); 
    const isMondayBlockedOutsideM50 = !this.dentroM50 && dayOfWeek === 1;

    const isBlockedByAdmin = isDateUnavailable(actualDate);

    // 1. SUMA DIAS HORA CORTE
    let leadDays = this.horaCorte ? 0 : 1;
    
    // 2. EXTRA FUERA M50
    if (!this.dentroM50){
      leadDays += 2; 
    } 
    // SOLO SE AÑADE PROD+24H SI ESTAMOS DENTRO DE M50
    if (this.dentroM50){
      if (this.cartPlusOne) {
          leadDays += 1; 
      }
    }
   
    //SUMA EN MS DE DÍAS 
    const msInDay = 86400000;
    const firstAvailableDate = today + (leadDays * msInDay);

    //RESTRICCIONES DENTRO DE UNA VENTANA DE UNA SEMANA
    let firstValidStart = null;

    if (!this.dentroM50) {
      const allowedDays = getAllowedWeekdays(this.todaysDate, this.horaCorte);
      const possibleDates = allowedDays.map(day =>
        getNextWeekday(this.todaysDate, day)
      );

      firstValidStart = Math.min(...possibleDates);
    }

    const isWeekend = (dayOfWeek === 0 || dayOfWeek === 6);
    const isPastOrLeadTime = checkDate <= firstAvailableDate;
    
    let isRestrictedWeekday = false;

    if (!this.dentroM50 && firstValidStart) {
      const allowedDays = getAllowedWeekdays(this.todaysDate, this.horaCorte);
      if (checkDate < firstValidStart) {
        if (!allowedDays.includes(dayOfWeek)) {
          isRestrictedWeekday = true;
        }
      }
    }


    // --- EVALUATE ---
    let isDisabled = false;
    let reason = "";
    if (isMondayBlockedOutsideM50) {
      isDisabled = true;
      reason = "No realizamos entregas los lunes fuera de M50.";
    } else if ( checkDate === today) {
        isDisabled = true;
        reason = "Requiere un día de preparación.";
    } else if (checkDate < today) {
        isDisabled = true;
        reason = "Las fechas pasadas no están disponibles.";
    } else if (isWeekend) {
        isDisabled = true;
        reason = "Estamos cerrados los fines de semana.";
    } else if (isPastOrLeadTime) {
        isDisabled = true;
        reason = `Requiere un día de preparación.`;
    } else if (isRestrictedWeekday) {
        isDisabled = true;
        reason = "Las entregas en esta área solo estan disponibles de martes a viernes.";
    } else if (isBlockedByAdmin) {
      isDisabled = true;
      reason = "Fecha no disponible.";
    }

    if (checkDate === today) dayEl.classList.add('cal__date--today');

    if (isDisabled) {
      dayEl.classList.add('cal__date--disabled');

        dayEl.addEventListener('click', () => {
            errorEl.style.display = 'block';
            errorEl.innerHTML = reason;
            setTimeout(() => { errorEl.style.display = 'none'; }, 3000);
        });
    } else {
        dayEl.classList.add('cal__date--active');
        dayEl.addEventListener('click', () => {
            errorEl.style.display = 'none';
            document.querySelectorAll('.cal__date--selected').forEach(el => el.classList.remove('cal__date--selected'));
            dayEl.classList.add('cal__date--selected');
            
            const formattedDate = actualDate.toLocaleDateString('es-ES', { 
                weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' 
            });
            this.pickedLabel.innerHTML = formattedDate;
            this.hiddenInput.value = formattedDate;
        });
    }

    this.monthArea.appendChild(dayEl);
  }
};

document.addEventListener('DOMContentLoaded', () => {
    const calendarBody = document.querySelector('[data-calendar-area="month"]');

  if (isUserInMadridTimezone()) {
    vanillacalendar.init();
  } else {
    calendarBody.innerHTML = `
      <div style="
        padding: 20px;
        text-align: center;
        color: #d9534f;
        font-weight: 600;
      ">
        Las entregas solo están disponibles en la zona y horario de Madrid
      </div>
    `;
  }
});
</script>

