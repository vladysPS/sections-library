<section class="p-{{ section.id }}">
    <div class="calendar-container">
        <div class="container">
            <div class="cal">
                <div class="cal__header">
                    <button class="btn-action" data-calendar-toggle="previous" aria-label="Previous Month">
                        <svg height="24" viewBox="0 0 24 24" width="24"><path d="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z"></path></svg>
                    </button>
                    <div class="cal__header__label" data-calendar-label="month"></div>
                    <button class="btn-action" data-calendar-toggle="next" aria-label="Next Month">
                        <svg height="24" viewBox="0 0 24 24" width="24"><path d="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z"></path></svg>
                    </button>
                </div>
                <div class="cal__week">
                    <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
                </div>
                <div class="cal__body" data-calendar-area="month"></div>
            </div>

            <p class="demo-picked">
                <strong>Date picked:</strong> <span data-calendar-label="picked">Please select a date</span>
            </p>
            <p class="cal-error-message" id="cal-error" style="display:none; color: #d9534f; font-weight: bold; margin-top: 10px;"></p>
            <input type="hidden" name="attributes[Delivery Date]" id="calendar-date-input">
        </div>
    </div>
</section>

<style>
.p-{{ section.id }} {
  --primary-color: #0A9297;
  --bg-light: #E7E9ED;
  --text-main: #333;
  --cell-size: 40px; /* Fixed size for the day circles */

  .container {
    width: 96%;
    margin: 2rem auto;
    max-width: 450px;
    text-align: center;
  }

  .cal {
    width: 100%;
    background-color: #fff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    border: 1px solid var(--bg-light);
  }

  .cal__header {
    display: flex;
    padding: 1.2rem;
    align-items: center;
    justify-content: space-between;
  }

  .btn-action {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    display: flex;
    align-items: center;
    transition: opacity 0.2s;
  }
  
  .cal__header svg { fill: var(--primary-color); }
  .cal__header__label { font-weight: 800; font-size: 1.1rem; }

  .cal__week {
    display: flex;
    background-color: var(--bg-light);
  }

  .cal__week span {
    flex: 0 0 14.285%;
    font-size: 0.7rem;
    padding: 10px 0;
    text-transform: uppercase;
    font-weight: 700;
    color: #666;
  }

  .cal__body {
    display: flex;
    flex-wrap: wrap;
    padding: 10px 0;
    min-height: 280px; /* Prevents height bounce between 5 and 6 row months */
  }

  .cal__date {
    flex: 0 0 14.285%;
    height: 48px; /* Fixed height for the grid cell */
    display: flex;
    justify-content: center;
    align-items: center;
    box-sizing: border-box;
  }

  /* Inner Circle - This prevents the bounce because the border/bg is inside a fixed box */
  .cal__date span {
    width: var(--cell-size);
    height: var(--cell-size);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%; /* Circular look */
    transition: all 0.2s ease;
    border: 2px solid transparent; /* Placeholder to prevent shift */
    font-size: 0.9rem;
  }

  /* Today's style: Teal border, no fill */
  .cal__date--today span {
    border-color: var(--primary-color);
    color: var(--primary-color);
    font-weight: bold;
  }

  .cal__date--active { cursor: pointer; }

  .cal__date--active:hover span {
    background-color: #f0f0f0;
  }

  /* Selected state: Solid fill */
  .cal__date--selected span {
    background-color: var(--primary-color) !important;
    color: #fff !important;
    border-color: var(--primary-color) !important;
  }

  .cal__date--disabled {
    opacity: 0.25;
    cursor: not-allowed !important;
  }

  .demo-picked {
    margin-top: 1.5rem;
    font-size: 0.9rem;
    color: var(--text-main);
  }
  .cal-error-message {
  font-size: 0.85rem;
  min-height: 1.2rem; /* Keeps space so layout doesn't jump when it appears */
}
}
</style>

<script>
const vanillacalendar = {
  monthArea: document.querySelector('[data-calendar-area="month"]'),
  nextBtn: document.querySelector('[data-calendar-toggle="next"]'),
  prevBtn: document.querySelector('[data-calendar-toggle="previous"]'),
  label: document.querySelector('[data-calendar-label="month"]'),
  pickedLabel: document.querySelector('[data-calendar-label="picked"]'),
  hiddenInput: document.getElementById('calendar-date-input'),
  
  date: new Date(),
  todaysDate: new Date(),

  // SETTINGS
  horaCorte: true, 

  init: function () {
    this.date.setDate(1);
    this.render();
    this.createListeners();
  },

  createListeners: function () {
    this.nextBtn.addEventListener('click', (e) => {
      e.preventDefault();
      this.date.setMonth(this.date.getMonth() + 1);
      this.render();
    });
    this.prevBtn.addEventListener('click', (e) => {
      e.preventDefault();
      this.date.setMonth(this.date.getMonth() - 1);
      this.render();
    });
  },

  render: function () {
    this.monthArea.innerHTML = '';
    const month = this.date.getMonth();
    const year = this.date.getFullYear();
    
    const monthName = new Intl.DateTimeFormat('en-US', { month: 'long' }).format(this.date);
    this.label.innerHTML = `${monthName} ${year}`;

    let firstDay = new Date(year, month, 1).getDay(); 
    let offset = firstDay === 0 ? 6 : firstDay - 1; 

    for (let i = 0; i < offset; i++) {
      const emptyDiv = document.createElement('div');
      emptyDiv.className = 'cal__date';
      this.monthArea.appendChild(emptyDiv);
    }

    const daysInMonth = new Date(year, month + 1, 0).getDate();
    for (let i = 1; i < daysInMonth + 1; i++) {
      const actualDate = new Date(year, month, i);
      this.createDay(i, actualDate);
    }
  },

createDay: function (num, actualDate) {
  const dayEl = document.createElement('div');
  const errorEl = document.getElementById('cal-error');
  dayEl.className = 'cal__date';
  dayEl.innerHTML = `<span>${num}</span>`;
  
  const checkDate = new Date(actualDate).setHours(0,0,0,0);
  const today = new Date(this.todaysDate).setHours(0,0,0,0);
  
  const leadDays = this.horaCorte ? 1 : 2;
  const msInDay = 86400000;
  const firstAvailable = today + (leadDays * msInDay);

  // IF DATE IS RESTRICTED
  if (checkDate <= firstAvailable) {
    dayEl.classList.add('cal__date--disabled');
    
    // Logic for the error message
    dayEl.addEventListener('click', () => {
      errorEl.style.display = 'block';
      if (checkDate === today) {
        errorEl.innerHTML = "Today is not available for selection.";
      } else if (checkDate < today) {
        errorEl.innerHTML = "You cannot select a past date.";
      } else {
        errorEl.innerHTML = `This date requires at least ${leadDays + 1} days of preparation.`;
      }
      
      // Auto-hide error after 3 seconds
      setTimeout(() => { errorEl.style.display = 'none'; }, 3000);
    });

  } 
  // IF DATE IS AVAILABLE
  else {
    dayEl.classList.add('cal__date--active');
    dayEl.addEventListener('click', () => {
      errorEl.style.display = 'none'; // Hide error if they pick a valid date
      document.querySelectorAll('.cal__date--selected').forEach(el => el.classList.remove('cal__date--selected'));
      dayEl.classList.add('cal__date--selected');
      
      const formattedDate = actualDate.toLocaleDateString('en-US', { 
          weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' 
      });
      
      this.pickedLabel.innerHTML = formattedDate;
      this.hiddenInput.value = formattedDate;
    });
  }

  this.monthArea.appendChild(dayEl);
}
};

document.addEventListener('DOMContentLoaded', () => {
  vanillacalendar.init();
});
</script>

